{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=HOST;Database=gp-erp;Uid=USER;Pwd=PASSWORD;Convert Zero Datetime=True;Allow Zero Datetime=True;"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_64_CHAR_RANDOM_SECRET",
    "Issuer": "GPInventory",
    "Audience": "GPInventory"
  },
  "Fintoc": {
    "SecretKey": "sk_live_REPLACE_WITH_REAL_KEY"
  },
  "MercadoPago": {
    // Clave AES-256 del SERVIDOR para encriptar/desencriptar los tokens MP de cada negocio.
    // Genera una clave random de exactamente 32 caracteres ASCII y ponla aquí (o en env var).
    // NUNCA pongas aquí el Access Token de ningún negocio — esos van en la DB encriptados.
    //
    // Generar clave:
    //   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
    //   openssl rand -hex 16
    "EncryptionKey": "REPLACE_WITH_32_CHAR_RANDOM_KEY_HERE"
  },
  "Resend": {
    // Obtener en https://resend.com — tier gratuito 3.000 emails/mes
    // Dev: usar clave re_test_xxx (no envía realmente)
    // Prod: usar clave re_live_xxx con dominio verificado granpasochile.cl
    "ApiKey": "re_REPLACE_WITH_RESEND_API_KEY",
    "From": "no-reply@granpasochile.cl",
    "FromName": "Gran Paso"
  },
  // URL base del frontend de auth — se usa para construir los links de reset password
  "AppUrl": "https://auth.granpasochile.cl"
}
